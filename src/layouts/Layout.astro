---
import { ViewTransitions } from "astro:transitions";
import { SEO } from "astro-seo";
import { background } from "../images/images.js";
import { Image } from "astro:assets";
import "@fontsource/roboto";
import "../styles/global.css";

import { seoConfig } from "../services/pwaConfig";

interface Props {
  title: string;
}

const { title } = Astro.props;

const ogImageUrl =
  typeof seoConfig.image.url === "string" ? seoConfig.image.url : seoConfig.image.url.src;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={seoConfig.description}
      openGraph={{
        basic: {
          title: title,
          type: "website",
          image: ogImageUrl,
        },
        image: {
          width: seoConfig.image.width,
          height: seoConfig.image.height,
          alt: seoConfig.image.alt,
        },
        optional: {
          siteName: seoConfig.siteName,
          description: seoConfig.description,
        },
      }}
      twitter={{
        card: seoConfig.twitter.card,
      }}
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/ico" href="/icon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="min-h-screen bg-[rgb(var(--ui-bg))] text-[rgb(var(--ui-text))]">
    <div class="absolute inset-0 z-0">
      <Image
        src={background}
        alt="Windows background"
        class="object-cover object-center w-screen h-screen"
        width="1080"
        height="720"
      />
    </div>
    <div class="relative z-10 font-sans">
      <slot />
    </div>
    <style is:global>
      code {
        font-family:
          Menlo,
          Monaco,
          Lucida Console,
          Liberation Mono,
          DejaVu Sans Mono,
          Bitstream Vera Sans Mono,
          Courier New,
          monospace;
      }
    </style>
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.5.2/dist/cdn.min.js"
    ></script>
  </body>
</html>
